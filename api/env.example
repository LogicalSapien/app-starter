# ============================================================
# API Configuration
# Copy this file to .env and fill in your values
# Or use Doppler: doppler setup && doppler run -- npm run dev
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development                    # development | testing | production

# ── Database (Required) ────────────────────────────────────
# PostgreSQL connection string
# Local:    postgresql://postgres:postgres@localhost:5432/app_starter
# Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_starter

# ── Supabase Auth (Required) ──────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...                # Public anon key (safe for frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Secret service role key (server-only!)

# ── CORS (Required for production) ────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true                 # Set to false to disable
RATE_LIMIT_WINDOW_MS=60000              # Window in ms (default: 1 minute)
RATE_LIMIT_MAX=100                      # Max requests per window per IP

# ── Logging ───────────────────────────────────────────────
# Levels: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# ── Error Monitoring (Optional) ──────────────────────────
# Get DSN from: https://sentry.io → Create Node.js project
# SENTRY_DSN=https://your-key@sentry.io/your-project-id
