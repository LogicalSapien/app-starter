{
  "name": "app-starter-api",
  "version": "1.0.0",
  "description": "Full-stack starter API — Express, TypeScript, Prisma, Supabase Auth",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "start:doppler": "doppler setup --no-interactive && doppler run -- node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "dev:doppler": "doppler setup --no-interactive && doppler run -- nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts,.js --max-warnings 100",
    "lint:fix": "eslint . --ext .ts,.js --max-warnings 100 --fix",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test jest --watchman=false",
    "test:watch": "cross-env NODE_ENV=test jest --watch --watchman=false",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --watchman=false",
    "test:ci": "cross-env NODE_ENV=test jest --coverage --ci --watchAll=false --testTimeout=60000 --watchman=false",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:doppler": "doppler setup --no-interactive && doppler run -- prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:reset:doppler": "doppler setup --no-interactive && doppler run -- prisma migrate reset",
    "db:studio": "prisma studio",
    "db:studio:doppler": "doppler setup --no-interactive && doppler run -- prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:doppler": "doppler setup --no-interactive && doppler run -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.39.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.5.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "nodemon": "^3.0.2",
    "prisma": "^5.17.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "api",
    "backend",
    "express",
    "typescript",
    "prisma",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
