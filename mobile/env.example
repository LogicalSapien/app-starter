# ============================================================
# Mobile Configuration (React Native / Expo)
# Variables prefixed with EXPO_PUBLIC_ are embedded at build time
# Copy this file to .env or use Doppler
# ============================================================

# ── API Connection (Required) ─────────────────────────────
# Use your machine's local IP for physical device testing (not localhost)
# Dev:  http://localhost:3001/api/v1  or  http://192.168.x.x:3001/api/v1
# Prod: https://api.yourdomain.com/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ── Supabase Auth (Required) ─────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Environment ──────────────────────────────────────────
APP_ENV=dev                             # dev | tst | prd

# ── Error Monitoring (Optional) ──────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
# EXPO_PUBLIC_SENTRY_ORG=your-org
# EXPO_PUBLIC_SENTRY_PROJECT=your-project
