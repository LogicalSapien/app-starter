# ============================================================
# UI Configuration (React / Vite)
# All variables must be prefixed with VITE_ to be accessible
# Copy this file to .env or use Doppler
# ============================================================

# ── API Connection (Required) ─────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1

# ── Supabase Auth (Required) ─────────────────────────────
# Same URL and anon key as the API (anon key is safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Environment ──────────────────────────────────────────
VITE_ENVIRONMENT=development            # development | testing | production

# ── Error Monitoring (Optional) ──────────────────────────
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
