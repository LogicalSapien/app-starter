# ============================================================
# Agentic AI Configuration (Python / FastAPI)
# Copy this file to .env or use Doppler
# ============================================================

# ── AI Keys (at least one required) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Database (Required) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_starter

# ── Server ───────────────────────────────────────────────
PORT=8000
HOST=127.0.0.1                          # Use 0.0.0.0 in Docker containers
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO                          # DEBUG, INFO, WARNING, ERROR

# ── Environment ──────────────────────────────────────────
APP_ENV=development                     # development | testing | production
