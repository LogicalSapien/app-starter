[run]
source = .
omit =
    tests/*
    venv/*
    .venv/*
    __pycache__/*
    *.pyc

[report]
show_missing = true
skip_covered = false
fail_under = 50
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    pass
    \.\.\.

[html]
directory = htmlcov
